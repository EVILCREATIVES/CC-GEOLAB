# Server-side Gemini API key for /api/gemini
GOOGLE_API_KEY=your_google_ai_studio_key

# Optional Cesium token for terrain/assets
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token

# Neon PostgreSQL (pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ccgeolab?sslmode=require

# Vercel Blob (from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Google Drive service account JSON (one line, escaped). Required for the
# "Open in Google Docs" report export. Create a service account in Google
# Cloud, enable the Drive API, generate a JSON key, and paste the entire
# JSON object as the value here.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Optional: Drive folder id where generated docs are stored. If omitted,
# docs are placed in the service account's root drive (still accessible
# via the returned link).
GOOGLE_DRIVE_FOLDER_ID=

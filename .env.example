# Server-side Gemini API key for /api/gemini
GOOGLE_API_KEY=your_google_ai_studio_key

# Optional Cesium token for terrain/assets
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token

# Neon PostgreSQL (pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ccgeolab?sslmode=require

# Vercel Blob (from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Public Google OAuth Client ID — used by "Open in Google Docs".
# Create in Google Cloud Console → APIs & Services → Credentials →
# Create Credentials → OAuth client ID → Web application.
# Authorized JavaScript origins: your app URL (e.g. https://cc-geolab.vercel.app
# and https://www.ccexplorations.com if embedded).
# No redirect URI required (we use the implicit token flow in the browser).
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
